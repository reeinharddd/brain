# Brain Station - AI Local Stack Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git - it should be in .gitignore

# ============================================================================
# OPEN WEBUI CONFIGURATION
# ============================================================================

# Secret key for WebUI session encryption
# Generate a strong random key: openssl rand -base64 32
WEBUI_SECRET_KEY=changeme-please-generate-a-strong-key

# UID/GID for running containers (should match your user)
UID=1000
GID=1000

# ============================================================================
# MCP FILESYSTEM CONFIGURATION
# ============================================================================

# SECURITY CRITICAL: Set this to the specific directory you want to expose
# Default is ./workspace (relative to ai-local directory)
# Examples:
#   WORKSPACE_DIR=./workspace           # Only ai-local/workspace
#   WORKSPACE_DIR=/home/user/projects   # Specific projects folder
#   WORKSPACE_DIR=/tmp/scratch          # Temporary only
#
# WARNING: Setting this to /home/username exposes ALL your files!
WORKSPACE_DIR=./workspace

# ============================================================================
# OLLAMA CONFIGURATION
# ============================================================================

# Ollama API endpoint (usually the bridge on 11435)
OLLAMA_BASE_URL=http://host.docker.internal:11435

# Optional: API Key for Ollama (if you enable auth in Ollama)
# OLLAMA_API_KEY=

# ============================================================================
# QDRANT CONFIGURATION
# ============================================================================

# Qdrant is accessible at localhost:6333
# No additional config needed for local development

# ============================================================================
# OPTIONAL: CLOUD PROVIDER API KEYS (for fallback)
# ============================================================================

# These are used by .brain system when local models aren't available
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# GITHUB_TOKEN=

# ============================================================================
# SECURITY WARNINGS
# ============================================================================
#
# 1. NEVER commit this file with real values to git
# 2. Rotate API keys regularly
# 3. Use least privilege - limit WORKSPACE_DIR to what's needed
# 4. All services bind to localhost (127.0.0.1) only by default
# 5. Change default WEBUI_SECRET_KEY immediately
#
