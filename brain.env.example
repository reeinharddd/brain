# brain.env.example
# User-specific configuration for the brain repo.
# Copy to ~/.brain/brain.env and fill in your values.
# This file is gitignored - never commit brain.env.
#
# brain.env is sourced by install.sh, doctor.sh, and agent-runner.py
# automatically if it exists at $BRAIN_DIR/brain.env

# ── Identity ─────────────────────────────────────────────────────────────────
# Your name as it appears in brain repo headers and git commits.
# Defaults to: $(git config user.name)
# BRAIN_USER="your-github-username"

# ── LLM Providers ────────────────────────────────────────────────────────────
# Set whichever keys you have. agent-runner.py auto-selects based on what's set.
# ANTHROPIC_API_KEY="sk-ant-..."
# OPENAI_API_KEY="sk-..."
# GEMINI_API_KEY="..."
# OLLAMA_BASE_URL="http://localhost:11434"   # for local models

# ── Default LLM backend ──────────────────────────────────────────────────────
# Which provider to use when multiple keys are set.
# Options: auto | anthropic | openai | gemini | ollama
# "auto" picks the first available from: anthropic -> openai -> gemini -> ollama
# BRAIN_LLM_BACKEND="auto"

# ── Memory: Cloud sync options ────────────────────────────────────────────────

# Option A: Mem0 (hosted memory, syncs across all devices automatically)
# Sign up at: https://app.mem0.ai  - free tier available
# MEM0_API_KEY="m0-..."

# Option B: Qdrant Cloud (hosted vector DB, syncs across devices)
# Sign up at: https://cloud.qdrant.io  - free tier: 1GB, 1 cluster
# Leave as localhost for local-only usage.
# QDRANT_URL="https://your-cluster.qdrant.io"
# QDRANT_API_KEY="your-qdrant-api-key"

# Option C: Upstash Vector (serverless, pay-per-use, zero infra)
# Sign up at: https://console.upstash.com  - free tier: 10k vectors
# UPSTASH_VECTOR_URL="https://xxx.upstash.io"
# UPSTASH_VECTOR_TOKEN="your-token"

# Option D: Git-backed memory sync (no external service, just git)
# The MCP memory JSON is committed and pushed automatically after each session.
# BRAIN_MEMORY_GIT_SYNC="true"    # push memory JSON to git after /handover
# BRAIN_MEMORY_GIT_REMOTE="origin"

# ── Embedding backend ─────────────────────────────────────────────────────────
# Used by embed.py and vector-sync-qdrant.sh
# Options: auto | openai | local | hash
# "auto" picks best available. "local" requires: pip install sentence-transformers
# BRAIN_EMBED_BACKEND="auto"
# BRAIN_EMBED_MODEL="all-MiniLM-L6-v2"   # for local backend

# ── Telemetry ─────────────────────────────────────────────────────────────────
# Disable telemetry logging to logs/telemetry.ndjson
# BRAIN_TELEMETRY_ENABLED="false"
