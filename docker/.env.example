# ═══════════════════════════════════════════════════════════
#  brain/docker/.env.example
#  Copy to: ~/.brain/docker/.env  (never commit .env)
#  Required for docker compose up to work
# ═══════════════════════════════════════════════════════════

# ── Required ─────────────────────────────────────────────────
# Your home directory (auto-expanded to give filesystem MCP access)
HOST_HOME=/home/your-username

# ── Optional — only needed for github MCP profile ────────────
# Get from: https://github.com/settings/tokens
# Permissions needed: repo, read:org
GITHUB_TOKEN=

# ── Optional — only needed for postgres MCP ──────────────────
DATABASE_URL=

# ── Port config (change if ports conflict) ───────────────────
MCP_MEMORY_PORT=3001
MCP_FILESYSTEM_PORT=3002
MCP_SEQUENTIAL_PORT=3003
MCP_CONTEXT7_PORT=3005
MCP_GITHUB_PORT=3004
